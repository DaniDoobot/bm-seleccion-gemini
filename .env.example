# ── Google Gemini ──────────────────────────────────────────────────────────────
# API key para acceder a Gemini Live.
# Obtenla en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Modelo de Gemini Live a utilizar.
# Valor validado en producción: models/gemini-3.1-flash-live-preview
GEMINI_MODEL=models/gemini-3.1-flash-live-preview

# Nombre de la voz preconfigurada de Gemini.
# Valor validado: Algieba (español de España, peninsular, adulta y natural)
GEMINI_VOICE_NAME=Algieba

# ── Configuración de generación de audio ───────────────────────────────────────
# Nivel de pensamiento interno del modelo. "minimal" reduce latencia.
GEMINI_THINKING_LEVEL=minimal

# ── Detección de actividad de voz (VAD) ───────────────────────────────────────
# Duración mínima de silencio (ms) para considerar fin de turno del usuario.
VAD_SILENCE_DURATION_MS=130

# Relleno de audio previo al inicio de habla detectado (ms).
VAD_PREFIX_PADDING_MS=120

# ── Servidor ────────────────────────────────────────────────────────────────────
# Puerto en el que escucha la aplicación.
PORT=8000

# URL pública del servicio (utilizada para construir callbacks futuros).
# Ejemplo: https://seleccion.bm.doobot.ai
PUBLIC_URL=https://tu-dominio.com

# URL pública de WebSocket del servicio para la integración de Twilio Streams.
# Ejemplo: wss://bmseleccion-backend.doobot.ai/voice/stream
PUBLIC_WS_BASE_URL=

# ── CORS ────────────────────────────────────────────────────────────────────────
# Orígenes permitidos separados por coma. Usa * solo en desarrollo.
# Ejemplo: https://yourapp.lovable.app,http://localhost:3000
CORS_ORIGINS=*

# ── Logging ─────────────────────────────────────────────────────────────────────
# Nivel de log: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
